	<array>
		<string>whatsapp</string>
		<string>mailto</string>
		<string>tel</string>
	</array>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>NSCameraUsageDescription</key>
	<string>$(PRODUCT_NAME) uses your camera to capture photos and videos that you can upload to
			posts, stories, and events.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Baccvs uses your location to show nearby posts, events, and users on the map. Your location is only visible when you choose to share it and check in. You can disable this anytime in settings.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Baccvs uses your location to show nearby posts, events, and users on the map. Your
		location is only shared when you choose to enable it.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>$(PRODUCT_NAME) uses your microphone to record audio while capturing videos for
			posts, stories, and events.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>$(PRODUCT_NAME) needs access to your photo library so you can select photos and
			videos to upload in posts, stories, and events.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>$(PRODUCT_NAME) needs access to your photo library so you can select photos and
			videos to upload in posts, stories, and events.</string>
